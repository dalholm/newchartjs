{
  "type": "module",
  "name": "newchartjs",
  "version": "0.2.1",
  "description": "A modern, lightweight charting library with SVG and Canvas rendering",
  "main": "dist/newchartjs.cjs.js",
  "module": "dist/newchartjs.esm.js",
  "browser": "dist/newchartjs.umd.js",
  "types": "dist/newchartjs.d.ts",
  "exports": {
    ".": {
      "import": "./dist/newchartjs.esm.js",
      "require": "./dist/newchartjs.cjs.js",
      "default": "./dist/newchartjs.umd.js"
    }
  },
  "files": [
    "dist/*.js",
    "src/**/*.js",
    "!src/**/*.test.js"
  ],
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "dev": "rollup -c -w & rollup-plugin-serve --host localhost --port 3000 --historyApiFallback",
    "serve": "node scripts/serve.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs:prepare": "mkdir -p docs/public/demo && cp demo/*.html docs/public/demo/ && cp demo/theme.js docs/public/ && cp dist/newchartjs.umd.js docs/public/",
    "docs:dev": "npm run docs:prepare && vitepress dev docs",
    "docs:build": "npm run docs:prepare && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "chart",
    "charting",
    "visualization",
    "svg",
    "canvas",
    "bar",
    "pie",
    "line",
    "responsive"
  ],
  "author": "Nyehandel",
  "license": "MIT",
  "homepage": "https://dalholm.github.io/newchartjs/",
  "bugs": "https://github.com/dalholm/newchartjs/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/dalholm/newchartjs.git"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "rollup": "^4.0.0",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^2.0.2",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  }
}
